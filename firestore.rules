rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // 公開プロフィール(名前・写真・友達コード)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;

      // 通知設定は本人しか読み書きできない(ミュートは相手に見えない)
      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // プッシュ通知トークンも本人のみ
      match /fcmTokens/{token} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // 筋トレ記録(docId = YYYY-MM-DD)。記録本体はCloud Functionsのみ書き込み。
      // 終了時に本人が書くフィールド(振り返り・終了時刻・ひとこと・詳細な記録)だけ更新できる
      match /sessions/{day} {
        allow read: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['mood', 'moodAt', 'endedAt', 'doneMessage', 'note']);
      }
    }

    // 友達コード → uid の逆引き
    match /friendCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // 友達申請(docId = from_to で重複申請を防ぐ)
    match /requests/{reqId} {
      allow create: if request.auth != null
        && request.resource.data.from == request.auth.uid
        && reqId == request.resource.data.from + '_' + request.resource.data.to;
      // 単独取得はdocIdで判定する(申請済みチェックは未存在のdocを読むため、
      // resource.data を参照する条件では常に拒否される)
      allow get: if request.auth != null && request.auth.uid in reqId.split('_');
      allow list, delete: if request.auth != null
        && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
    }

    // 友達関係(docId = 小さいuid_大きいuid)
    match /friends/{fid} {
      // 単独取得はdocIdで判定する(申請前の「すでに友達か」チェックは
      // 未存在のdocを読むため、resource.data を参照する条件では常に拒否される)
      allow get: if request.auth != null && request.auth.uid in fid.split('_');
      allow list, delete: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null
        && request.resource.data.users.size() == 2
        && request.auth.uid in request.resource.data.users;
    }
  }
}
